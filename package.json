{
  "name": "trail-runner-coach",
  "version": "2.4.1",
  "private": true,
  "type": "module",
  "description": "Mobile-first local-first bilingual trail coach with preserved wearable sync and Apple Health insights, visible score impact, automatic bridge pull and Shortcuts diagnostics",
  "scripts": {
    "dev": "npx wrangler dev",
    "deploy": "npx wrangler deploy",
    "test": "node --test",
    "check": "node scripts/verify.mjs && node --test",
    "deploy:dry-run": "npx wrangler deploy --dry-run",
    "setup:strava": "node scripts/setup-strava.mjs",
    "setup:backup": "node scripts/setup-cloud-backup.mjs",
    "setup:google-health": "node scripts/setup-google-health.mjs",
    "setup:apple-health-shortcut": "node scripts/setup-apple-health-shortcut.mjs"
  },
  "devDependencies": {
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.1.1",
    "wrangler": "4.103.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
