{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "trail-runner-coach-apple-health-sync",
  "main": "src/index.js",
  "compatibility_date": "2026-06-25",
  "vars": {
    "APP_ORIGIN": "https://trail-runner-coachs.YOUR-SUBDOMAIN.workers.dev"
  },
  "secrets": {
    "required": ["APPLE_HEALTH_BRIDGE_TOKEN", "APPLE_HEALTH_ENCRYPTION_KEY"]
  },
  "kv_namespaces": [
    { "binding": "APPLE_HEALTH_DATA", "id": "CREATE_WITH_SETUP_SCRIPT" }
  ]
}
